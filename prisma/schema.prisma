// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String?
  phone         String?
  dob           String?
  gender        String?
  avatar        String?
  memberSince   String         @default("Now")
  tier          String         @default("Silver")
  loyaltyPoints Int            @default(0)
  lifetimeSpend Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  addresses     Address[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  questions     Question[]
  answers       Answer[]
  stylePosts    StylePost[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── THEME PRESETS (admin-customizable design system) ───────────────────────

model Theme {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(false)
  settings  String   // JSON: { primary, accent, background, foreground, muted, radius, fontSerif, fontSans }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CATEGORIES (multi-level hierarchy) ─────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  parentId    String?
  icon        String?
  image       String?
  description String?
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")
  products Product[]
}

// ─── CATALOG ─────────────────────────────────────────────────────────────────

model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  brand           String   @default("MAISON ÉLÉGANCE")
  category        String
  subcategory     String
  price           Int
  compareAtPrice  Int?
  currency        String   @default("USD")
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  images          String   // JSON array as string (SQLite limitation)
  colors          String   // JSON array
  sizes           String   // JSON array
  badge           String?
  description     String
  shortDescription String
  materials       String   // JSON array
  craftsmanship   String
  care            String
  origin          String
  sustainability  String
  fit             String
  features        String   // JSON array
  sku             String   @unique
  inStock         Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Optional link to structured Category (multi-level). When null, falls back
  // to the flat `category` + `subcategory` string fields for backward compat.
  categoryId      String?
  categoryRef     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  reviews       Review[]
  orderItems OrderItem[]
  wishlistItems WishlistItem[]
  questions     Question[]
  stylePosts    StylePost[]
}

// ─── COMMERCE ────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  guestEmail      String?
  status          String      @default("Confirmed")
  subtotal        Int
  shipping        Int
  tax             Int
  total           Int
  shippingAddress String
  trackingNumber  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  image     String
  size      String
  color     String
  quantity  Int
  price     Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String
  fullName   String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String
  phone      String
  isDefault  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  authorName String
  rating    Int
  title     String?
  body      String
  images    String?  // JSON array of image URLs (customer photos)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([productId, userId])
}

// ─── COMMUNITY Q&A ──────────────────────────────────────────────────────────

model Question {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  authorName String
  body      String
  createdAt DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers  Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  userId     String?
  authorName String
  body       String
  isVerified Boolean  @default(false)
  helpful    Int      @default(0)
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─── STYLE FEED (community posts) ───────────────────────────────────────────

model StylePost {
  id        String   @id @default(cuid())
  userId    String?
  authorName String
  authorAvatar String?
  image     String
  caption   String
  productId String?  // optional: tagged product
  likes     Int      @default(0)
  createdAt DateTime @default(now())

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  comments PostComment[]
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  authorName String
  body      String
  createdAt DateTime @default(now())

  post StylePost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ─── SITE CONTENT (admin-editable homepage sections) ────────────────────────
//
// One row per section (heroCarousel, lookbook, exploreMaison, etc.).
// `data` is a JSON string with whatever fields that section needs:
//   - heroCarousel:  { slides: [{image, season, title, titleAccent, description, ctaLabel, ctaLink}] }
//   - lookbook:      { items: [{image, title, subtitle}] }
//   - exploreMaison: { items: [{image, title, description, ctaLink}] }
//   - followWorld:   { items: [{image, caption, link}] }
//   - atelierCircle: { title, subtitle, description, image, benefits[], ctaLabel }
//   - newThisSeason: { title, subtitle }
//   - flashSale:     { title, subtitle, image, endsAt, badge, discount }
//   - announcement:  { text, link, enabled }
//
// The public API returns all rows; the admin API allows GET/PUT per section.

model SiteContent {
  id        String   @id @default(cuid())
  section   String   @unique
  data      String   // JSON string
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ─── FESTIVAL THEMES (sale events: Black Friday, Diwali, etc.) ───────────────
//
// When isActive=true, the entire app's CSS variables are overridden with
// the values in `settings`, and a festive banner with countdown appears.
// Admin can schedule auto-activation via startDate/endDate.

model FestivalTheme {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  settings    String   // JSON: CSS variables + banner config
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
